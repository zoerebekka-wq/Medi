<!DOCTYPE html>
<html lang="el">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Medicosmetic Aesthetic Clinic</title>
  <style>
    :root {
      --topbar: #c3ab86;
      --hero: #b2a79b;
      --light: #f6f6f6;
      --text: #3f3a36;
      --muted: #a9926d;
      --white: #ffffff;
      --cta: #d1b07a;
      --cta-hover: #c5a168;
    }

    * { box-sizing: border-box; }

    html, body {
      margin: 0;
      padding: 0;
      background: var(--light);
      color: var(--text);
      font-family: Arial, Helvetica, sans-serif;
    }

    a {
      text-decoration: none;
      color: inherit;
    }

    .topbar {
      height: 55px;
      background: var(--topbar);
      color: #fff;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      padding: 0 28px;
      font-size: 14px;
      font-weight: 700;
      letter-spacing: 0;
    }

    .topbar-text {
      text-align: center;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      max-width: calc(100% - 220px);
    }

    .topbar-icons {
      position: absolute;
      right: 26px;
      top: 50%;
      transform: translateY(-50%);
      display: flex;
      gap: 18px;
      align-items: center;
    }

    .topbar-icons svg {
      width: 18px;
      height: 18px;
      fill: #fff;
      display: block;
    }

    .header {
      background: var(--light);
      padding-top: 26px;
    }

    .logo-wrap {
      display: flex;
      justify-content: center;
      align-items: center;
      margin-bottom: 38px;
    }

    .logo-wrap img {
      width: 350px;
      max-width: 80vw;
      height: auto;
      display: block;
    }

    .nav {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 84px;
      padding: 24px 30px 34px;
      font-size: 17px;
      color: var(--text);
      flex-wrap: wrap;
    }

    .nav a {
      line-height: 1;
      font-weight: 400;
    }

    .nav a.active {
      color: var(--muted);
    }

    .nav .caret {
      font-size: 13px;
      margin-left: 4px;
      position: relative;
      top: -1px;
    }

    .hero {
      background: var(--hero);
      border-bottom-left-radius: 28px;
      border-bottom-right-radius: 28px;
      overflow: hidden;
      position: relative;
      min-height: 765px;
    }

    .hero-inner {
      position: relative;
      width: 100%;
      min-height: 765px;
      overflow: hidden;
    }

    .hero-image {
      display: block;
      width: 100%;
      height: auto;
      position: relative;
      z-index: 1;
    }

    .intro-section {
      background: var(--light);
      padding: 90px 20px 80px;
      text-align: center;
    }

    .intro-wrap {
      max-width: 960px;
      margin: 0 auto;
    }

    .intro-kicker {
      color: var(--muted);
      font-size: 18px;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      margin: 0 0 18px;
    }

    .intro-title {
      margin: 0 0 24px;
      color: var(--text);
      font-family: Georgia, "Times New Roman", serif;
      font-weight: 400;
      font-size: 56px;
      line-height: 1.12;
      white-space: pre-line;
    }

    .intro-text {
      margin: 0 auto;
      max-width: 760px;
      color: #6b645d;
      font-size: 22px;
      line-height: 1.7;
    }

    @media (max-width: 1400px) {
      .nav {
        gap: 54px;
      }

      .hero {
        min-height: auto;
      }

      .hero-inner {
        min-height: auto;
      }

      .intro-title {
        font-size: 48px;
      }
    }

    @media (max-width: 1100px) {
      .topbar {
        height: auto;
        padding: 12px 20px;
        flex-direction: column;
        gap: 10px;
      }

      .topbar-text {
        max-width: 100%;
        white-space: normal;
      }

      .topbar-icons {
        position: static;
        transform: none;
      }

      .nav {
        gap: 28px 36px;
        font-size: 15px;
      }

      .intro-section {
        padding: 70px 20px 64px;
      }

      .intro-title {
        font-size: 42px;
      }

      .intro-text {
        font-size: 20px;
      }
    }

    @media (max-width: 700px) {
      .header {
        padding-top: 18px;
      }

      .logo-wrap {
        margin-bottom: 24px;
      }

      .logo-wrap img {
        width: 250px;
      }

      .nav {
        gap: 18px 22px;
        padding: 16px 16px 22px;
        font-size: 14px;
      }

      .hero {
        border-bottom-left-radius: 20px;
        border-bottom-right-radius: 20px;
      }

      .intro-section {
        padding: 56px 18px 52px;
      }

      .intro-kicker {
        font-size: 14px;
      }

      .intro-title {
        font-size: 32px;
      }

      .intro-text {
        font-size: 18px;
      }
    }
  </style>
</head>
